# Comma-separated list of host domains allowed as the Twitch embed `parent`.
# Twitch player embeds SILENTLY FAIL if this does not include the exact host
# the page is served from. Include every deploy domain plus localhost for dev.
#
# Copy this file to `.env` for local dev (localhost is always allowed implicitly,
# but listing it keeps behavior explicit), and set VITE_EMBED_PARENTS in the
# Netlify dashboard for production.
VITE_EMBED_PARENTS=localhost
